//

void run_test(char* src, char* words, char* result, int deleted)
{
    static int tests;
    tests += 1;
    printf("Test %.2i", tests);

    long n = strlen(src);
    char *clone = malloc(n + 1);
    memcpy(clone, src, n+1);
    
    int d = delete_words(clone, words);

    if (d == deleted && !strcmp(clone, result))
    {
        printf(" .....................................................[pass]\n");
    }
    else
    {
        printf(" .....................................................[fail]\n");
        printf("        expected src = \"%s\"\n", result);
        printf("                 ret = %i\n",     deleted);
        printf("             got src = \"%s\"\n", clone);
        printf("                 ret = %i\n",     d);
    }

    free(clone);
}


int main(void)
{
    
    run_test("aa bb cc",
         "bb",
         "aa cc",
         1);
  
    run_test("aa bb cc nejaka slova uprostred dd",
         "bb cc dd ahoj priklad slov",
         "aa nejaka slova uprostred",
         3);

    run_test("aa bb cc dd ee",
         "bb aa dd ee cc",
         "",
         5);

    run_test("aa bb cc dd",
         "ee ff gg hh",
         "aa bb cc dd",
         0);
  
    run_test("",
         "a b c d",
         "",
         0);

    run_test("aa bb cc dd",
         "",
         "aa bb cc dd",
         0);

    // muzete si doplnit dalsi testy

    
    return 0;
}

