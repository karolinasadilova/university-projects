int delete_words(char *src, char*words) {
char result[1000];
int rpos = 0;
int deleted = 0;

int i = 0;
 while (src[i] != '\0') {

    //nacte jedno slovo ze src
    char word[100];
    int wpos = 0;

    while (src[i] != '\0' && src[i] != ' ') {
        word[wpos++] = src[i++];
    }
    word[wpos] = '\0';

    //preskoci mezeru
    if (src[i] == ' ')
        i++;

    //overuje jestli je v seznamu words
    int remove = 0;

    int j = 0;
    while (words[j] != '\0') {
        char w[100];
        int k = 0;

        while (words[j] != '\0' && words[j] != ' ') {
            w[k++] = words[j++];
        }
        w[k] = '\0';

        if (words[j] == ' ')
            j++;

        if (strcmp(word, w) == 0) {
            remove = 1;
            break;
        }
    }

    if (remove) {
        deleted++;
        continue;
    }

    //prida slovo do resultu
    if (rpos != 0) {
        result[rpos++] = ' ';
    }

    for (int x = 0; word[x] != '\0'; x++) {
        result[rpos++] = word[x];
    }
}

result[rpos] = '\0';

//vysledek
strcpy(src, result);

return deleted;
}



